ONLINE_MODE=true
HOST=0.0.0.0
PORT=8787
PUBLIC_BASE_URL=https://your-manga-tool.example.com
DATA_DIR=./data

# Persistent X schedule backup.
# If Railway Volume is not mounted at /data, set these in Railway Variables
# to keep scheduled posts through redeploys. The schedule contains X tokens,
# so it is encrypted before being written to GitHub.
PERSISTENCE_GITHUB_TOKEN=
PERSISTENCE_GITHUB_REPOSITORY=UmbrellaParade/4comic-online
PERSISTENCE_GITHUB_BRANCH=main
PERSISTENCE_SCHEDULE_PATH=.persistent/x-scheduled-posts.enc.json
PERSISTENCE_ENCRYPTION_KEY=

# OpenAI image generation
OPENAI_API_KEY=

# Optional: required when syncing private browser settings such as API keys,
# WordPress app passwords, and X OAuth client secrets between PC and phone.
CLIENT_STATE_SYNC_KEY=

# WordPress credentials. Put real values in Railway Variables, not GitHub.
WP_VEL13_SITE_URL=https://example.com
WP_VEL13_USERNAME=
WP_VEL13_APP_PASSWORD=
WP_CARLA_SITE_URL=https://example.com
WP_CARLA_USERNAME=
WP_CARLA_APP_PASSWORD=
WP_BELBO_SITE_URL=https://example.com
WP_BELBO_USERNAME=
WP_BELBO_APP_PASSWORD=

# Optional: Obsidian-compatible file output root on a mounted disk
VAULT_ROOT=./data/vault

# File retry tuning for cloud disks
FILE_RETRY_ATTEMPTS=10
FILE_RETRY_DELAY_MS=180
