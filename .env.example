ONLINE_MODE=true
HOST=0.0.0.0
PORT=8787
PUBLIC_BASE_URL=https://your-manga-tool.example.com
DATA_DIR=./data

# OpenAI image generation
OPENAI_API_KEY=

# WordPress credentials. Put real values in Railway Variables, not GitHub.
WP_VEL13_SITE_URL=https://example.com
WP_VEL13_USERNAME=
WP_VEL13_APP_PASSWORD=
WP_CARLA_SITE_URL=https://example.com
WP_CARLA_USERNAME=
WP_CARLA_APP_PASSWORD=
WP_BELBO_SITE_URL=https://example.com
WP_BELBO_USERNAME=
WP_BELBO_APP_PASSWORD=

# Optional: Obsidian-compatible file output root on a mounted disk
VAULT_ROOT=./data/vault

# File retry tuning for cloud disks
FILE_RETRY_ATTEMPTS=10
FILE_RETRY_DELAY_MS=180
